# Copy to backend/.env and fill in your Atlas connection string.
# In MongoDB Atlas: Database -> Connect -> Drivers -> copy URI (replace <password>).

MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
DATABASE_NAME=collegeconnect

# Firebase Admin (verify ID tokens). Same project as VITE_FIREBASE_* in the frontend.
# Firebase Console -> Project settings -> Service accounts -> Generate new private key -> save JSON under backend/
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-adminsdk-xxxxx.json
# Or use the standard GCP env var (absolute path recommended):
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/serviceAccount.json

# Resend — required when a student books a session (email to advisor’s college/personal email)
# Create an API key at https://resend.com/api-keys — never commit real keys.
RESEND_API_KEY=re_xxxxxxxx
# Required: address on a domain you verified at https://resend.com/domains (otherwise Resend only allows test sends to your account email).
RESEND_FROM=CollegeConnect <bookings@yourdomain.com>

# AWS S3 — college ID + profile images (browser uploads via presigned PUT)
AWS_ACCESS_KEY_ID=AKIAxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=ap-south-1
S3_BUCKET=your-bucket-name
# Optional; college ID keys: {prefix}/advisors|students/{firebaseUid}/front_....jpg
S3_COLLEGE_IDS_PREFIX=college-ids
# Optional; profile avatar keys: {prefix}/advisors|students/{firebaseUid}/avatar_....jpg
S3_PROFILE_PICTURES_PREFIX=profile-pictures
#
# After filling the above:
# 1) IAM: attach a policy like backend/aws/iam-api-user-policy.example.json (replace bucket name; PutObject required).
# 2) Bucket CORS (required for browser PUT): edit backend/aws/s3-cors.example.json — add your production site URL
#    to AllowedOrigins — then either paste the rules in S3 console → Permissions → CORS, or run:
#    cd backend && .venv\Scripts\python scripts\apply_s3_cors.py   (needs s3:PutBucketCORS on the bucket)
# 3) Confirm API sees config: GET http://127.0.0.1:8000/api/meta/s3  → "configured": true
