# Copy to .env for local dev. Vite exposes only vars prefixed with VITE_.

# Production site URL (no trailing slash). Used for canonical URLs, Open Graph, and JSON-LD.
# Local dev can omit. Before deploy: set and run `npm run sitemap`, then add the Sitemap line to public/robots.txt.
# VITE_SITE_URL=https://your-project.web.app

# FastAPI + MongoDB (optional). Leave unset to use Vite dev proxy: /api/students → http://127.0.0.1:8000
# VITE_REST_API_URL=http://127.0.0.1:8000

# Firebase web app (Firebase Console → Project settings → Your apps)
# Dev: open http://localhost:5173 (not only 127.0.0.1) unless you add 127.0.0.1 under
# Firebase Console → Authentication → Settings → Authorized domains.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
